# ─── 데이터 소스 ─────────────────────────────────────────────
# mock = 목업 데이터(백엔드 없이) · api = NestJS 백엔드 호출
# 실배포 기준이라 기본 api. 로컬은 .env.development에서 mock으로 자동 전환.
NEXT_PUBLIC_DATA_SOURCE=api

# ─── 백엔드 (NestJS API) ─────────────────────────────────────
# 환경별로 다르게 설정:
#   local      http://localhost:4000/api
#   staging    https://skein-api-staging.<region>.run.app/api
#   production https://api.skein.app/api
NEXT_PUBLIC_BASE_URL=http://localhost:4000/api

# ─── Supabase (Auth — JWT 발급) ──────────────────────────────
# 백엔드와 동일 프로젝트 사용. 대시보드 Connect → Framework 탭에서 복사.
# ⚠️ staging / production은 별도 Supabase 프로젝트 권장 (DB 격리)
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# 신규 publishable key (sb_publishable_...). 구 anon key도 폴백 지원.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# service_role 등 비밀키는 프론트에 두지 않음 (백엔드/프록시 서버에서만)
